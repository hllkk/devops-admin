{
  "environmentVariables": {
    "VIBECODING_VERSION": "1.0.0",
    "LANGUAGE": "zh-Hans"
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)"
    ],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{ "type": "command", "command": "node .claude/hooks/context-loader.cjs" }]
      }
    ]
  }
}