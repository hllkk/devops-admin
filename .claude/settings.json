{
  "environmentVariables": {
    "VIBECODING_VERSION": "1.0.0",
    "LANGUAGE": "zh-Hans",
    "LC_ALL": "zh-Hans",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_SUBAGENT_MODEL": "kimi-k2.5"
  },
  "permissions": {
    "allow": [
      "Bash(cd *)",
      "Bash(git *)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)"
    ],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{ "type": "command", "command": "node .claude/hooks/context-loader.cjs" }]
      }
    ]
  }
}